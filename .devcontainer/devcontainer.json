{
  "name": "OpenClaw Dev",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "node": "20"
  },
  "postCreateCommand": "npm install -g openclaw@latest",
  "postStartCommand": "openclaw gateway --port 18789 &",
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md"]
    }
  }
}
